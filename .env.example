# 0G Galileo testnet
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16602

# Wallet private key with 0G testnet tokens.
# Do not commit a real key.
PRIVATE_KEY=
WALLET_PHRASE=
WALLET_ADDRESS=

# Optional. If unset, scripts scan common Ethereum derivation paths when WALLET_ADDRESS is present.
WALLET_DERIVATION_PATH=

# Set after deployment.
OPENGAP_REGISTRY_ADDRESS=

# Use "local" for demo stubs or "0g" for live 0G Chain registry writes.
OPENGAP_REGISTRY_PROVIDER=local

# Use "local" for demo stubs or "0g" for live 0G Storage uploads.
OPENGAP_STORAGE_PROVIDER=local
ZERO_G_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
